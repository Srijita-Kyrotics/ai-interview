# ── App ────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false

# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_interview
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Auth / JWT ────────────────────────────────────────────────────────
JWT_SECRET=              # leave blank to auto-generate and persist
JWT_EXPIRY_HOURS=24

# ── SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_character_gmail_app_password
SMTP_FROM=your_email@gmail.com

# ── External APIs ─────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
JUDGE0_API_KEY=your_rapidapi_judge0_key
JUDGE0_HOST=judge0-ce.p.rapidapi.com

# ── CORS (comma-separated origins) ───────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Uploads ───────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=10485760

# ── OTP / Captcha ────────────────────────────────────────────────────
OTP_TTL_SECONDS=300
CAPTCHA_TTL_SECONDS=300
OTP_RATE_LIMIT=5
OTP_RATE_WINDOW=600

# ── Rate Limits ───────────────────────────────────────────────────────
CODE_RATE_LIMIT=20
CODE_RATE_WINDOW=600
AI_RATE_LIMIT=10
AI_RATE_WINDOW=600
ADMIN_RATE_LIMIT=30
ADMIN_RATE_WINDOW=600

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Session cleanup ───────────────────────────────────────────────────
SESSION_RETENTION_DAYS=30
